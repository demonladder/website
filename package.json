{
    "name": "gddl",
    "version": "3.0.0-beta.14",
    "author": "Daniel Iversen Sato <diversensato@gmail.com>",
    "license": "SEE LICENSE IN LICENSE",
    "private": true,
    "type": "module",
    "repository": {
        "url": "git+https://github.com/demonladder/website.git",
        "type": "git"
    },
    "homepage": "https://github.com/demonladder/website#readme",
    "bugs": "https://github.com/demonladder/website/issues",
    "funding": {
        "type": "ko-fi",
        "url": "https://ko-fi.com/gddemonladder"
    },
    "scripts": {
        "dev": "bunx --bun vite --host",
        "type-check": "tsc --noEmit",
        "build": "tsc && vite build",
        "build:staging": "vite build --mode staging",
        "lint": "eslint src --ignore-pattern \"**/*.d.ts*\" --report-unused-disable-directives --max-warnings 0",
        "preview": "vite preview",
        "prepare": "husky",
        "format": "prettier --write **/*.[jt]s",
        "format:check": "prettier --check **/*.[jt]s",
        "version:prerelease": "npm version prerelease --preid=beta --no-git-tag-version"
    },
    "dependencies": {
        "@boxicons/react": "^1.0.3",
        "@react-hook/resize-observer": "^2.0.2",
        "@tanstack/react-query": "^5.90.21",
        "@tanstack/react-query-devtools": "^5.91.3",
        "@types/js-cookie": "^3.0.6",
        "axios": "^1.13.6",
        "chart.js": "^4.5.1",
        "chartjs-adapter-date-fns": "^3.0.0",
        "country-flag-icons": "^1.6.15",
        "date-fns": "^4.1.0",
        "fast-xml-parser": "^5.5.6",
        "js-cookie": "^3.0.5",
        "lodash": "^4.18.1",
        "ms": "^2.1.3",
        "perlin-simplex": "^0.0.3",
        "qrcode": "^1.5.4",
        "react": "^19.2.4",
        "react-chartjs-2": "^5.3.1",
        "react-colorful": "^5.6.1",
        "react-dom": "^19.2.4",
        "react-intersection-observer": "^9.16.0",
        "react-keybind": "^0.10.0",
        "react-lite-youtube-embed": "^2.6.0",
        "react-markdown": "^10.1.0",
        "react-p5": "^1.4.1",
        "react-router": "^7.8.2",
        "react-router-dom": "^7.13.1",
        "react-toastify": "^11.0.5",
        "react-use-websocket": "^4.13.0",
        "swiper": "^12.1.2",
        "use-query-params": "^2.2.2",
        "usehooks-ts": "^3.1.1"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@eslint/js": "^9.22.0",
        "@stylistic/eslint-plugin": "^5.9.0",
        "@tailwindcss/vite": "^4.2.1",
        "@types/lodash": "^4.17.24",
        "@types/ms": "^0.7.34",
        "@types/qrcode": "^1.5.6",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.4",
        "eslint": "^9.39.3",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.26",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "prettier": "^3.8.1",
        "tailwindcss": "^4.0.12",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vite": "^7.3.2"
    },
    "lint-staged": {
        "*.[jt]s?(x)": "prettier --write",
        "*.css": "prettier --write",
        "*.json": "prettier --write"
    }
}
